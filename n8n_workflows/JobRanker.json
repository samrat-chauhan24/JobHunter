    {
      "parameters": {
        "jsCode": "const jobs = $(\"ReadJobs\").all().map(i => i.json);\n\n// All 85 AI scores\nconst scores = $input.all().map(i => i.json);\n\n// IDs that passed\nconst allowed = new Set(\n  scores\n    .filter(s => s.atsScore >= 70)\n    .map(s => s.uniqueId)\n);\n\n// Return original jobs\nreturn jobs\n  .filter(job => allowed.has(job.uniqueId))\n  .map(job => ({ json: job }));"
      },
