    {
      "parameters": {
        "jsCode": "let counter = $getWorkflowStaticData('global');\n\nif (counter.index === undefined) {\n    counter.index = 0;\n}\n\nconst ranker = counter.index % 2;\n\ncounter.index++;\n\nreturn [\n    {\n        json: {\n            ...$json,\n            ranker\n        }\n    }\n];"
      },
