    {
      "parameters": {
        "jsCode": "const { resume, jobs } = $input.first().json;\n\nconst allJobs = jobs[0].jobs;\n\nconst CHUNK_SIZE = 5;\n\nconst output = [];\n\nfor (let i = 0; i < allJobs.length; i += CHUNK_SIZE) {\n    output.push({\n        json: {\n            resume,\n            jobs: allJobs.slice(i, i + CHUNK_SIZE)\n        }\n    });\n}\n\nreturn output;"
      },
