      "id": "be2ab5b9-ae2b-4565-a644-7cf5cb91a1d0",
      "name": "JobRanker1"
    },
    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of $input.all()) {\n\n    const text = item.json.output;\n\n    const match = text.match(/\\[\\s*{[\\s\\S]*}\\s*\\]/);\n\n    if (!match) {\n        continue;\n    }\n\n    const jobs = JSON.parse(match[0]);\n\n    for (const job of jobs) {\n        output.push({\n            json: job\n        });\n    }\n}\n\nreturn output;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3584,
