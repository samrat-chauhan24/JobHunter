    {
      "parameters": {
        "jsCode": "const resume = $input.first().json;\n\nconst roleKeywords = [\n  \"AI Engineer\",\n  \"GenAI Engineer\",\n  \"Backend Developer\",\n  \"Python Developer\",\n  \"FastAPI Developer\",\n  \"Full Stack Developer\",\n  \"Software Engineer\",\n  \"Software Developer\",\n  \"GenAi Engineer\",\n  \"MERN Stack Developer\",\n  \"Full Stack Ai Engineer\"\n];\n\n// Infer experience\nconst experience =\n  resume.experience && resume.experience.length\n    ? resume.experience\n    : \"Fresher\";\n\n// Collect project technologies\nconst projectKeywords = [];\n\nfor (const project of resume.projects || []) {\n  for (const tech of project.technologies || []) {\n    if (!projectKeywords.includes(tech)) {\n      projectKeywords.push(tech);\n    }\n  }\n}\n\nconst compactResume = {\n\n\n  experience,\n\n\n  rolePreferences: roleKeywords,\n\n  skills: [...new Set(resume.skills || [])],\n\n  \n\n};\n\nreturn [\n  {\n    json: compactResume\n  }\n];"
      },
